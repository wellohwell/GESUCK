rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "wahyulaksanajayakusuma@gmail.com" || 
        request.auth.token.email == "admin@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.upper() in ["MANAGER", "OWNER", "ADMIN"])
      );
    }

    function hasPermission(permission) {
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             doc.data.keys().hasAll(["permissions"]) &&
             permission in doc.data.permissions;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role helpers using current doc lookup
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.upper() : "MEMBER";
    }

    function getUserBranch() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAll(["branchId"]) ? 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId : null;
    }

    function isOwner() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.upper() == "OWNER";
    }

    function isStaff() {
      return isSignedIn() && getUserRole() == "STAFF";
    }

    function hasBranchAccess(docData) {
      return isAdmin() || (isSignedIn() && (!docData.keys().hasAll(["branchId"]) || docData.branchId == getUserBranch()));
    }

    function isSPV() {
      return isSignedIn() && getUserRole() == "SPV";
    }

    function isSurvey() {
      return isSignedIn() && getUserRole() == "SURVEY";
    }

    function isGudang() {
      return isSignedIn() && getUserRole() == "GUDANG";
    }

    function isSales() {
      return isSignedIn() && getUserRole() == "SALES";
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin() || (isStaff() && hasBranchAccess(existing())));
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow get: if true;
    }

    match /markets/{marketId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /market_plans/{planId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /clients/{clientId} {
      allow get: if isSignedIn() && hasBranchAccess(existing());
      allow list: if isSignedIn() && hasBranchAccess(resource.data) && (
        isAdmin() || isSPV() || isStaff() || isSurvey() || isGudang() || resource.data.ownerId == request.auth.uid
      );
      allow create: if isSignedIn() && hasBranchAccess(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && hasBranchAccess(existing()) && hasBranchAccess(incoming()) && (
        isAdmin() || isOwner() || isStaff() ||
        (isSurvey() && existing().stage == "pipeline") ||
        (isGudang() && existing().stage == "client") ||
        existing().ownerId == request.auth.uid
      );
      allow delete: if isAdmin() && hasBranchAccess(existing());
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && hasBranchAccess(existing());
      allow list: if isSignedIn() && hasBranchAccess(resource.data) && (isAdmin() || isSPV() || resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && hasBranchAccess(incoming()) && (incoming().ownerId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && hasBranchAccess(existing()) && hasBranchAccess(incoming()) && (isAdmin() || isSPV() || existing().ownerId == request.auth.uid);
      allow delete: if isAdmin() && hasBranchAccess(existing());
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && hasBranchAccess(existing());
      allow list: if isSignedIn() && hasBranchAccess(resource.data) && (
        isAdmin() || 
        isSPV() || 
        isStaff() || 
        (isSurvey() && resource.data.type == "survey") ||
        (isGudang() && resource.data.type == "delivery") ||
        resource.data.ownerId == request.auth.uid
      );
      allow create: if isSignedIn() && hasBranchAccess(incoming()) && (incoming().ownerId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && hasBranchAccess(existing()) && hasBranchAccess(incoming()) && (
        isAdmin() || 
        isSPV() || 
        (isSurvey() && existing().type == "survey") ||
        (isGudang() && existing().type == "delivery") ||
        existing().ownerId == request.auth.uid
      );
      allow delete: if isAdmin() && hasBranchAccess(existing());
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid || 
        resource.data.roleTarget == getUserRole() ||
        resource.data.roleTarget == "ALL"
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        isAdmin() ||
        existing().userId == request.auth.uid
      );
    }

    match /activities/{activityId} {
      allow read: if isSignedIn() && hasBranchAccess(resource.data) && (
        isAdmin() || 
        isSPV() || 
        isStaff() || 
        (isSurvey() && resource.data.category in ["task", "workflow", "system"]) ||
        (isGudang() && resource.data.category in ["task", "workflow", "order"]) ||
        resource.data.actorId == request.auth.uid
      );
      allow create: if isSignedIn() && (hasBranchAccess(incoming()) || isStaff());
      allow update, delete: if isAdmin() && hasBranchAccess(existing());
    }

    match /modules/{moduleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /navigation/{navId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if true;
      allow write: if isAdmin();

      match /master_markets/{marketId} {
        allow get, list: if isSignedIn() && (isAdmin() || getUserBranch() == branchId || getUserBranch() == null);
        allow write: if isAdmin();
      }
    }
  }
}

