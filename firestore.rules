rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.keys().hasAll(["email"]) && (request.auth.token.email == "wahyulaksanajayakusuma@gmail.com" || request.auth.token.email == "admin@gmail.com")) ||
        getUserRole() in ["MANAGER", "OWNER", "ADMIN"]
      );
    }

    function hasPermission(permission) {
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             doc.data.keys().hasAll(["permissions"]) &&
             permission in doc.data.permissions;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role helpers using current doc lookup
    function getUserRole() {
      return (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAll(["role"]))
             ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.upper()
             : "MEMBER";
    }

    function getUserBranch() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAll(["branchId"]) ? 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId : null;
    }

    function isOwner() {
      return isSignedIn() && getUserRole() == "OWNER";
    }

    function isStaff() {
      return isSignedIn() && getUserRole() == "STAFF";
    }

    function hasBranchAccess(docData) {
      return isAdmin() || (isSignedIn() && (!docData.keys().hasAll(["branchId"]) || docData.branchId == getUserBranch()));
    }

    function isSPV() {
      return isSignedIn() && (getUserRole() == "SPV" || getUserRole() == "SUPERVISOR");
    }

    function isSurvey() {
      return isSignedIn() && getUserRole() == "SURVEY";
    }

    function isGudang() {
      return isSignedIn() && getUserRole() == "GUDANG";
    }

    function isSales() {
      return isSignedIn() && getUserRole() == "SALES";
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin() || (isStaff() && hasBranchAccess(existing())));
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow get: if true;
    }

    match /markets/{marketId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /market_plans/{planId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /clients/{clientId} {
      allow get: if isSignedIn() && (isAdmin() || hasBranchAccess(existing()));
      allow list: if isSignedIn() && (
        isAdmin() || (
          hasBranchAccess(resource.data) && (
            isSPV() || isStaff() || isSurvey() || isGudang() || resource.data.ownerId == request.auth.uid
          )
        )
      );
      allow create: if isSignedIn() && (isAdmin() || (hasBranchAccess(incoming()) && incoming().keys().hasAll(['ownerId']) && incoming().ownerId == request.auth.uid));
      allow update: if isSignedIn() && (
        isAdmin() || (
          hasBranchAccess(existing()) && hasBranchAccess(incoming()) && (
            isOwner() || isStaff() || isSPV() ||
            (isSurvey() && existing().keys().hasAll(['stage']) && existing().stage == "pipeline") ||
            (isGudang() && existing().keys().hasAll(['stage']) && existing().stage == "client") ||
            (existing().keys().hasAll(['ownerId']) && existing().ownerId == request.auth.uid) ||
            (existing().keys().hasAll(['createdBy']) && existing().createdBy == request.auth.uid)
          )
        )
      );
      allow delete: if isSignedIn() && (
        isAdmin() || (
          hasBranchAccess(existing()) && (
            isOwner() || isStaff() || isSPV() ||
            (isSurvey() && existing().keys().hasAll(['stage']) && existing().stage == "pipeline") ||
            (isGudang() && existing().keys().hasAll(['stage']) && existing().stage == "pipeline") ||
            (existing().keys().hasAll(['ownerId']) && existing().ownerId == request.auth.uid) ||
            (existing().keys().hasAll(['createdBy']) && existing().createdBy == request.auth.uid)
          )
        )
      );
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isAdmin() || hasBranchAccess(existing()));
      allow list: if isSignedIn() && (
        isAdmin() || (
          hasBranchAccess(resource.data) && (isSPV() || resource.data.ownerId == request.auth.uid)
        )
      );
      allow create: if isSignedIn() && (isAdmin() || (hasBranchAccess(incoming()) && incoming().ownerId == request.auth.uid));
      allow update: if isSignedIn() && (
        isAdmin() || (
          hasBranchAccess(existing()) && hasBranchAccess(incoming()) && (
            isSPV() || existing().ownerId == request.auth.uid
          )
        )
      );
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && (isAdmin() || hasBranchAccess(existing()));
      allow list: if isSignedIn() && (
        isAdmin() || (
          hasBranchAccess(resource.data) && (
            isSPV() || 
            isStaff() || 
            (isSurvey() && resource.data.type == "survey") ||
            (isGudang() && resource.data.type == "delivery") ||
            resource.data.ownerId == request.auth.uid
          )
        )
      );
      allow create: if isSignedIn() && (isAdmin() || (hasBranchAccess(incoming()) && incoming().ownerId == request.auth.uid));
      allow update: if isSignedIn() && (
        isAdmin() || (
          hasBranchAccess(existing()) && hasBranchAccess(incoming()) && (
            isSPV() || 
            (isSurvey() && existing().type == "survey") ||
            (isGudang() && existing().type == "delivery") ||
            existing().ownerId == request.auth.uid
          )
        )
      );
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        isAdmin() || (
          hasBranchAccess(resource.data) && (
            resource.data.userId == request.auth.uid || 
            resource.data.roleTarget == getUserRole() ||
            resource.data.roleTarget == "ALL"
          )
        )
      );
      allow create: if isSignedIn() && (isAdmin() || hasBranchAccess(incoming()));
      allow update, delete: if isSignedIn() && (
        isAdmin() ||
        existing().userId == request.auth.uid
      );
    }

    match /activities/{activityId} {
      allow read: if isSignedIn() && (
        isAdmin() || (
          hasBranchAccess(resource.data) && (
            isSPV() || 
            isStaff() || 
            (isSurvey() && resource.data.category in ["task", "workflow", "system"]) ||
            (isGudang() && resource.data.category in ["task", "workflow", "order"]) ||
            resource.data.actorId == request.auth.uid
          )
        )
      );
      allow create: if isSignedIn() && (isAdmin() || hasBranchAccess(incoming()) || isStaff());
      allow update, delete: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow read: if isSignedIn() && (isAdmin() || (hasBranchAccess(resource.data) && isSPV()));
      allow create: if isSignedIn() && (isAdmin() || hasBranchAccess(incoming()));
      allow update, delete: if isAdmin();
    }

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /loginHistory/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /modules/{moduleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /automation_settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notification_queue/{queueId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /navigation/{navId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if true;
      allow write: if isAdmin();

      match /master_markets/{marketId} {
        allow get, list: if isSignedIn() && (isAdmin() || getUserBranch() == branchId || getUserBranch() == null);
        allow write: if isAdmin();
        
        match /operations/{opId} {
          allow read: if isSignedIn() && (isAdmin() || getUserBranch() == branchId || getUserBranch() == null);
          allow write: if isAdmin();
        }
      }
    }

    match /weeklyReports/{reportId} {
      allow read, write: if isSignedIn();
    }

    match /reportNotes/{noteId} {
      allow read, write: if isSignedIn();
    }
  }
}

