{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "SPV", "Sales"] },
        "status": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" }
      }
    },
    "Market": {
      "title": "Market",
      "description": "Market data",
      "type": "object",
      "properties": {
        "nama_pasar": { "type": "string" },
        "wilayah": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "MarketPlan": {
      "title": "Market Plan",
      "description": "Daily activity plans for markets",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "dayStart": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Client": {
      "title": "Client",
      "description": "Client data",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "nama": { "type": "string" },
        "nomor": { "type": "string" },
        "usaha": { "type": "string" },
        "alamat": { "type": "string" },
        "kategori": { "type": "string", "enum": ["baru", "eks", "langgan"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Client orders",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "ownerId": { "type": "string" },
        "barang": { "type": "string" },
        "angsuran": { "type": "number" },
        "tenorDays": { "type": "number" },
        "status": { "type": "string", "enum": ["waiting", "approved", "rejected", "shipped", "active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "dueAt": { "type": "string", "format": "date-time" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "Tasks related to orders",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "clientId": { "type": "string" },
        "ownerId": { "type": "string" },
        "assignedTo": { "type": "string" },
        "type": { "type": "string", "enum": ["survey", "delivery", "followup"] },
        "status": { "type": "string", "enum": ["pending", "done"] },
        "dueAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Activity": {
      "title": "Activity",
      "description": "System and user activity logs",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "category": { "type": "string", "enum": ["user", "order", "task", "workflow", "notification", "system"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "actorId": { "type": "string" },
        "actorName": { "type": "string" },
        "actorRole": { "type": "string" },
        "targetId": { "type": "string" },
        "targetType": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "category", "title", "description", "actorId", "actorName", "actorRole", "createdAt"]
    },
    "ModuleConfig": {
      "title": "Module Config",
      "description": "Centralized system feature flag and module governance",
      "type": "object",
      "properties": {
        "moduleId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "enabled": { "type": "boolean" },
        "visibleInNav": { "type": "boolean" },
        "allowedRoles": { "type": "array" },
        "allowedBranches": { "type": "array" },
        "betaMode": { "type": "boolean" },
        "maintenanceMode": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/markets/{marketId}": {
      "schema": "Market",
      "description": "Market list"
    },
    "/market_plans/{planId}": {
      "schema": "MarketPlan",
      "description": "Market visit plans"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Client list"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order list"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Task list"
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Audit and operational activity logs"
    },
    "/modules/{moduleId}": {
      "schema": "ModuleConfig",
      "description": "Feature flag and modular configuration settings"
    }
  }
}
