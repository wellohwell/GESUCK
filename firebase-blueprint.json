{
  "entities": {
    "Market": {
      "title": "Market",
      "description": "Details about a market location, its area, and operational hours.",
      "type": "object",
      "properties": {
        "nama_pasar": { "type": "string" },
        "wilayah": { "type": "string" },
        "buka_harian": { "type": "boolean" },
        "pasaran": { "type": "array", "items": { "type": "string" } },
        "jam_buka": { "type": "string" },
        "kategori": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["nama_pasar", "wilayah", "buka_harian", "jam_buka", "kategori"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Mapping of a user to a specific market for a specific date.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nama": { "type": "string" },
        "email": { "type": "string" },
        "foto": { "type": "string" },
        "pendamping": { "type": "string" },
        "pasarId": { "type": "string" },
        "pasarNama": { "type": "string" },
        "tanggal": { "type": "string", "format": "YYYY-MM-DD" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "nama", "email", "pasarId", "pasarNama", "tanggal", "createdAt"]
    },
    "MarketPlan": {
      "title": "Market Plan",
      "description": "Sales field operation market plan.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "city": { "type": "string" },
        "marketType": { "type": "string" },
        "marketName": { "type": "string" },
        "marketJam": { "type": "string" },
        "dayStart": { "type": "string", "format": "YYYY-MM-DD" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "city", "marketType", "marketName", "dayStart", "createdAt"]
    },
    "VisitReport": {
      "title": "Visit Report",
      "description": "Report submitted after a market visit.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "marketName": { "type": "string" },
        "customerName": { "type": "string" },
        "date": { "type": "string", "format": "YYYY-MM-DD" },
        "status": { "type": "string", "enum": ["planned", "visited", "pending", "canceled", "reschedule"] },
        "result": { "type": "string", "enum": ["closing", "follow_up", "no_response", "rejected", "maintenance"] },
        "notes": { "type": "string" },
        "photoUrl": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "marketName", "date", "status", "result", "createdAt"]
    },
    "MonthlySummary": {
      "title": "Monthly Summary",
      "description": "Aggregated stats for a user for a specific month.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "month": { "type": "string", "format": "YYYY-MM" },
        "totalVisits": { "type": "number" },
        "visitsByResult": {
          "type": "object",
          "properties": {
            "closing": { "type": "number" },
            "follow_up": { "type": "number" },
            "no_response": { "type": "number" },
            "rejected": { "type": "number" },
            "maintenance": { "type": "number" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "month", "totalVisits", "visitsByResult", "updatedAt"]
    }
  },
  "firestore": {
    "markets/{marketId}": {
      "schema": "Market",
      "description": "Collection of all markets."
    },
    "assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Daily market assignments. ID is usually 'YYYY-MM-DD_uid' or similar."
    },
    "market_plans/{planId}": {
      "schema": "MarketPlan",
      "description": "Sales live market plans for field operations."
    },
    "visit_reports/{reportId}": {
      "schema": "VisitReport",
      "description": "Completed visit reports indexed by user and date."
    },
    "monthly_summaries/{summaryId}": {
      "schema": "MonthlySummary",
      "description": "Monthly performance summaries for KPI tracking."
    },
    "admins/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string" }
        }
      },
      "description": "List of admin users."
    },
    "marketLocks/{lockId}": {
      "schema": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Locks for markets to prevent duplicate selection."
    },
    "users/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" },
          "displayName": { "type": "string" },
          "email": { "type": "string" },
          "photoURL": { "type": "string" },
          "role": { "type": "string", "enum": ["Penyelam", "Admin"] },
          "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
          "lastLogin": { "type": "string", "format": "date-time" }
        },
        "required": ["uid", "role", "status"]
      },
      "description": "User profiles and registration details."
    }
  }
}
